{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!dagger/sdk", "!dist"]
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	},
	"formatter": {
		"enabled": true
	},
	"overrides": [
		{
			"includes": [
				"src/engine/projection.ts",
				"src/engine/projection.test.ts",
				"src/views/ProjectionView.tsx"
			],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	]
}
